.p-feats{list-style:none;margin-bottom:18px;}
.p-feats li{font-size:12px;color:var(--mid);padding:5px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:7px;}
.p-card.hot .p-feats li{color:rgba(255,255,255,0.65);border-bottom-color:rgba(255,255,255,0.07);}
.p-feats li:last-child{border-bottom:none;}
.ck{color:var(--green);flex-shrink:0;font-size:12px;}
.p-card.hot .ck{color:#4ade80;}
.btn-p{display:block;text-align:center;padding:11px;border-radius:8px;font:700 11px var(--mono);letter-spacing:0.05em;text-decoration:none;cursor:pointer;border:none;transition:all 0.2s;}
.bp-red{background:var(--red);color:#fff;}
.bp-red:hover{background:var(--red2);}
.bp-white{background:#fff;color:var(--ink);}
.bp-white:hover{background:rgba(255,255,255,0.9);}
.bp-outline{background:transparent;color:var(--ink);border:1.5px solid var(--border2);}
.bp-outline:hover{border-color:var(--ink);}
.stripe-bar{background:var(--paper);border:1px solid var(--border);border-radius:12px;padding:16px 20px;display:flex;align-items:center;gap:14px;margin-top:22px;font-size:13px;color:var(--mid);}

/* ─── BUILD WITH ────────────────────────────────────────────── */
.use-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden;}
.uc{background:var(--white);padding:26px 22px;transition:background 0.2s;}
.uc:hover{background:var(--paper);}
.uc.accent{background:var(--ink);}
.uc.accent:hover{background:var(--ink2);}
.uc-icon{font-size:26px;margin-bottom:12px;}
.uc-title{font:800 16px var(--sans);color:var(--ink);margin-bottom:7px;}
.uc.accent .uc-title{color:#fff;}
.uc-desc{font-size:13px;color:var(--mid);line-height:1.65;}
.uc.accent .uc-desc{color:rgba(255,255,255,0.45);}
.uc-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px;}
.uc-tag{font:600 9px var(--mono);letter-spacing:0.06em;padding:3px 8px;border-radius:4px;background:var(--paper2);border:1px solid var(--border);color:var(--mid);}

/* ─── SPONSOR ───────────────────────────────────────────────── */
.sponsor-section{background:var(--paper);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.sponsor-inner{max-width:1280px;margin:0 auto;padding:56px 28px;display:grid;grid-template-columns:auto 1px 1fr auto;gap:32px;align-items:center;}
.sp-name{font-family:var(--display);font-size:42px;font-weight:800;letter-spacing:1px;color:var(--ink);white-space:nowrap;}
.sp-name em{color:var(--red);font-style:normal;}
.sp-divider{background:var(--border2);height:60px;width:1px;}
.sp-copy h3{font:700 17px var(--sans);color:var(--ink);margin-bottom:6px;}
.sp-copy p{font-size:14px;color:var(--mid);max-width:400px;line-height:1.65;}
.btn-sp{padding:12px 22px;background:var(--ink);color:#fff;font:700 12px var(--mono);letter-spacing:0.08em;border-radius:8px;text-decoration:none;white-space:nowrap;transition:all 0.2s;}
.btn-sp:hover{background:var(--ink2);transform:translateY(-2px);}

/* ─── CTA BAND ──────────────────────────────────────────────── */
.cta-band{background:var(--red);padding:64px 28px;text-align:center;position:relative;overflow:hidden;}
.cta-band::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,rgba(255,255,255,0.02) 0,rgba(255,255,255,0.02) 1px,transparent 1px,transparent 8px);}
.cta-band h2{font-family:var(--display);font-size:clamp(36px,5vw,68px);font-weight:800;letter-spacing:-1.5px;color:#fff;line-height:1.0;margin-bottom:12px;position:relative;}
.cta-band p{font-size:16px;color:rgba(255,255,255,0.65);margin-bottom:28px;max-width:520px;margin-left:auto;margin-right:auto;position:relative;}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative;}
.btn-white{display:inline-flex;align-items:center;gap:7px;padding:13px 28px;background:#fff;color:var(--red);font:700 13px var(--mono);letter-spacing:0.05em;border-radius:9px;text-decoration:none;border:none;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 16px rgba(0,0,0,0.15);}
.btn-white:hover{background:rgba(255,255,255,0.9);transform:translateY(-2px);}
.btn-outline-white{display:inline-flex;align-items:center;gap:7px;padding:12px 24px;background:transparent;color:#fff;font:600 13px var(--mono);letter-spacing:0.04em;border-radius:9px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.3);cursor:pointer;transition:all 0.2s;}
.btn-outline-white:hover{border-color:#fff;background:rgba(255,255,255,0.08);}

/* ─── FOOTER ────────────────────────────────────────────────── */
footer{background:var(--ink);color:rgba(255,255,255,0.5);}
.footer-top{max-width:1280px;margin:0 auto;padding:60px 28px 40px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:44px;border-bottom:1px solid rgba(255,255,255,0.07);}
.fb p{font-size:13px;color:rgba(255,255,255,0.35);max-width:210px;line-height:1.7;margin:10px 0 18px;}
.social-row{display:flex;gap:8px;}
.s-btn{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.4);text-decoration:none;transition:all 0.2s;}
.s-btn:hover{background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.18);color:#fff;}
.s-btn svg{width:16px;height:16px;}
.footer-col h4{font:700 9px var(--mono);letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:14px;}
.footer-col ul{list-style:none;}
.footer-col li{margin-bottom:8px;}
.footer-col a{font-size:13px;color:rgba(255,255,255,0.45);text-decoration:none;transition:color 0.15s;}
.footer-col a:hover{color:#fff;}
.footer-bottom{max-width:1280px;margin:0 auto;padding:20px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.footer-copy{font:400 11px var(--mono);color:rgba(255,255,255,0.18);}
.footer-badges{display:flex;gap:8px;flex-wrap:wrap;}
.fb2{font:600 9px var(--mono);letter-spacing:0.06em;padding:3px 9px;border-radius:20px;border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.2);}

/* ─── MODAL ─────────────────────────────────────────────────── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(20,20,18,0.7);z-index:999;backdrop-filter:blur(8px);align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal{background:var(--white);border:1px solid var(--border);border-radius:16px;width:min(460px,92vw);padding:36px;position:relative;box-shadow:var(--shadow-lg);}
.modal-close{position:absolute;top:14px;right:14px;background:var(--paper);border:none;color:var(--mid);width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:all 0.15s;}
.modal-close:hover{color:var(--ink);}
.fg{margin-bottom:14px;}
.fg label{font:700 9px var(--mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--soft);display:block;margin-bottom:6px;}
.fg input{width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--ink);font:400 14px var(--sans);padding:11px 14px;border-radius:8px;outline:none;transition:border-color 0.15s;}
.fg input:focus{border-color:var(--red);}
.btn-checkout{width:100%;font:700 12px var(--mono);letter-spacing:0.06em;padding:14px;background:var(--green);color:#fff;border:none;border-radius:8px;cursor:pointer;transition:all 0.15s;margin-top:8px;}
.btn-checkout:hover{background:#099950;}
.btn-checkout:disabled{opacity:0.4;cursor:not-allowed;}

/* ─── TOAST ─────────────────────────────────────────────────── */
.toast{position:fixed;bottom:24px;right:24px;background:var(--ink);border:1px solid rgba(255,255,255,0.1);color:#fff;font:500 12px var(--mono);padding:12px 20px;border-radius:8px;z-index:9999;transform:translateY(60px);opacity:0;transition:all 0.25s;box-shadow:var(--shadow-lg);}
.toast.show{transform:translateY(0);opacity:1;}

/* ─── ANIMATIONS ─────────────────────────────────────────────── */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
.fu{animation:fadeUp 0.6s ease both;}
.d1{animation-delay:0.1s;}.d2{animation-delay:0.2s;}.d3{animation-delay:0.3s;}
.sfu{opacity:0;transform:translateY(18px);transition:opacity 0.55s ease,transform 0.55s ease;}
.sfu.vis{opacity:1;transform:none;}

/* ─── RESPONSIVE ─────────────────────────────────────────────── */
@media(max-width:1024px){.footer-top{grid-template-columns:1fr 1fr;gap:28px;}.sponsor-inner{grid-template-columns:1fr;gap:20px;}.sp-divider{display:none;}.feat-grid{grid-template-columns:1fr 1fr;}.code-inner{grid-template-columns:1fr;}.sport-panel.on{grid-template-columns:1fr;}}
@media(max-width:768px){
