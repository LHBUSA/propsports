<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0,viewport-fit=cover">
<title>PropSports API — MLB, NFL, NBA & NHL Sports Data for Developers</title>
<meta name="description" content="Real-time sports data API. 31+ endpoints across MLB, NFL, NBA, NHL. Statcast exit velocity, live scores, lineups, weather, odds. Free tier. From $9/mo.">
<link rel="canonical" href="https://propsports.proptechusa.ai/">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23D73B1A'/%3E%3Cpath d='M10 6L6 17H13L9 26L26 13H18L22 6H10Z' fill='white'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,700;1,700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#FAFAF7;--paper:#F3F2EE;--paper2:#ECEAE4;--white:#FFFFFF;
  --ink:#141412;--ink2:#1E1E1B;--mid:#5C5A54;--soft:#9B9990;
  --border:#E0DDD7;--border2:#CBC8C1;
  --red:#D73B1A;--red2:#E84E2B;--redbg:rgba(215,59,26,0.06);--redborder:rgba(215,59,26,0.15);
  --green:#0B7A45;--greenbg:rgba(11,122,69,0.06);
  --gold:#C17F24;--blue:#1A5FBF;
  --sans:'DM Sans',sans-serif;--serif:'Playfair Display',serif;--display:'Syne',sans-serif;--mono:'JetBrains Mono',monospace;
  --shadow-sm:0 1px 4px rgba(0,0,0,0.06),0 0 0 1px rgba(0,0,0,0.03);
  --shadow-md:0 4px 20px rgba(0,0,0,0.08),0 0 0 1px rgba(0,0,0,0.04);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.12),0 0 0 1px rgba(0,0,0,0.05);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;overflow-x:hidden;}
body{background:var(--cream);color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased;overflow-x:hidden;line-height:1.6;}

/* ─── LIVE TICKER ──────────────────────────────────────────── */
#ticker{background:var(--ink);height:34px;overflow:hidden;display:flex;align-items:center;position:relative;z-index:300;}
#ticker::before{content:'LIVE';position:absolute;left:0;z-index:2;background:var(--red);color:#fff;font:700 9px/34px var(--mono);letter-spacing:1.5px;padding:0 14px;height:100%;display:flex;align-items:center;}
#ticker::after{content:'';position:absolute;left:60px;z-index:2;width:24px;height:100%;background:linear-gradient(90deg,var(--ink),transparent);}
.tk-track{display:flex;white-space:nowrap;animation:tk 80s linear infinite;padding-left:72px;}
.tk-track:hover{animation-play-state:paused;}
.tk-item{display:inline-flex;align-items:center;gap:8px;padding:0 26px;font:500 10px var(--mono);color:rgba(255,255,255,0.45);border-right:1px solid rgba(255,255,255,0.07);}
.tk-item .sport{color:rgba(255,255,255,0.8);font-weight:700;}
.tk-item .score{color:#F5A623;font-weight:700;}
.tk-dot{width:5px;height:5px;border-radius:50%;background:var(--red);animation:blink 1.5s infinite;flex-shrink:0;}
@keyframes tk{from{transform:translateX(0);}to{transform:translateX(-50%);}}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.1;}}

/* ─── NAV ──────────────────────────────────────────────────── */
#nav{position:sticky;top:0;z-index:200;height:58px;display:flex;align-items:center;padding:0 0;background:rgba(250,250,247,0.94);backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid var(--border);transition:box-shadow 0.3s;}
#nav.scrolled{box-shadow:0 4px 24px rgba(0,0,0,0.08);}
.nav-i{max-width:1280px;margin:0 auto;width:100%;display:flex;align-items:center;padding:0 28px;}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none;flex-shrink:0;margin-right:20px;}
.logo svg{width:30px;height:30px;flex-shrink:0;}
.logo-t{font-family:var(--display);font-size:17px;font-weight:800;letter-spacing:0.5px;color:var(--ink);}
.logo-t span{color:var(--red);}
.nav-sports{display:flex;align-items:center;gap:1px;position:relative;}
.ns-btn{font:700 11px var(--mono);letter-spacing:0.05em;padding:6px 11px;background:transparent;color:var(--mid);border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all 0.18s;white-space:nowrap;}
.ns-btn:hover{color:var(--ink);}
.ns-btn.on{color:var(--red);}
.ns-slider{position:absolute;bottom:0;height:2px;background:var(--red);border-radius:1px;transition:all 0.3s cubic-bezier(0.4,0,0.2,1);}
.nav-r{margin-left:auto;display:flex;align-items:center;gap:6px;}
.nav-link{font:500 13px var(--sans);color:var(--mid);text-decoration:none;padding:6px 10px;border-radius:6px;transition:all 0.15s;}
.nav-link:hover{color:var(--ink);background:var(--paper);}
.nav-tag{font:700 9px var(--mono);letter-spacing:0.08em;padding:4px 10px;border-radius:20px;background:var(--greenbg);color:var(--green);border:1px solid rgba(11,122,69,0.2);}
.btn-red{display:inline-flex;align-items:center;gap:7px;padding:8px 18px;background:var(--red);color:#fff;font:700 12px var(--mono);letter-spacing:0.05em;border-radius:7px;text-decoration:none;border:none;cursor:pointer;transition:all 0.2s;box-shadow:0 2px 10px rgba(215,59,26,0.25);}
.btn-red:hover{background:var(--red2);transform:translateY(-1px);box-shadow:0 4px 18px rgba(215,59,26,0.35);}
.ham{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:6px;background:none;border:none;margin-left:8px;}
.ham span{display:block;width:20px;height:2px;background:var(--ink);border-radius:2px;transition:all 0.3s;}
.mob{display:none;position:fixed;inset:0;top:58px;background:var(--cream);z-index:150;padding:16px;flex-direction:column;gap:2px;overflow-y:auto;}
.mob.open{display:flex;}
.mob a,.mob button{display:block;padding:12px 14px;font:500 15px var(--sans);color:var(--ink);text-decoration:none;border-radius:8px;background:none;border:none;cursor:pointer;text-align:left;width:100%;transition:background 0.15s;}
.mob a:hover,.mob button:hover{background:var(--paper);}
.mob .btn-red{text-align:center;display:block;margin-top:10px;}

/* ─── HERO ─────────────────────────────────────────────────── */
.hero{position:relative;overflow:hidden;padding:72px 0 64px;}
.hero-bg{position:absolute;inset:0;pointer-events:none;}
.hero-lines{position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:64px 64px;opacity:0.4;}
.hero-accent{position:absolute;top:-120px;right:-80px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(215,59,26,0.07) 0%,transparent 65%);}
.hero-inner{max-width:1280px;margin:0 auto;padding:0 28px;display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;position:relative;z-index:1;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:7px;font:700 10px var(--mono);letter-spacing:0.15em;text-transform:uppercase;color:var(--red);background:var(--redbg);border:1px solid var(--redborder);padding:5px 14px;border-radius:20px;margin-bottom:16px;}
.h-dot{width:5px;height:5px;border-radius:50%;background:var(--red);animation:blink 1.5s infinite;}
h1{font-family:var(--display);font-size:clamp(52px,7vw,96px);font-weight:800;letter-spacing:-2px;line-height:0.95;color:var(--ink);margin-bottom:14px;}
h1 em{color:var(--red);font-style:normal;}
h1 .serif{font-family:var(--serif);font-weight:700;letter-spacing:-1px;}
.hero-lead{font-size:16px;color:var(--mid);max-width:470px;line-height:1.75;margin-bottom:26px;font-weight:400;}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;}
.btn-outline{display:inline-flex;align-items:center;gap:7px;padding:8px 18px;background:transparent;color:var(--ink);font:600 12px var(--mono);letter-spacing:0.04em;border-radius:7px;text-decoration:none;border:1.5px solid var(--border2);cursor:pointer;transition:all 0.2s;}
.btn-outline:hover{border-color:var(--ink);background:var(--paper);}
.trust-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.tr-pill{font:500 11px var(--sans);color:var(--mid);padding:4px 10px;border-radius:20px;border:1px solid var(--border);white-space:nowrap;}
.tr-pill.g{color:var(--green);border-color:rgba(11,122,69,0.25);background:var(--greenbg);}

/* ─── TERMINAL ─────────────────────────────────────────────── */
.term-shell{position:relative;}
.term-shadow{position:absolute;inset:-2px;border-radius:15px;background:linear-gradient(135deg,rgba(215,59,26,0.2),rgba(215,59,26,0.05) 50%,rgba(26,95,191,0.08));z-index:0;border-radius:17px;}
.term-box{position:relative;z-index:1;background:var(--ink2);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-lg);}
.term-tabs{display:flex;background:#111110;border-bottom:1px solid rgba(255,255,255,0.06);overflow-x:auto;scrollbar-width:none;}
.term-tabs::-webkit-scrollbar{display:none;}
.tt{font:500 10px var(--mono);letter-spacing:0.06em;padding:10px 13px;background:transparent;color:rgba(255,255,255,0.38);border:none;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all 0.15s;}
.tt.on{color:var(--red);border-bottom-color:var(--red);background:rgba(215,59,26,0.07);}
.tt:hover:not(.on){color:rgba(255,255,255,0.65);}
.tbar{background:#0C0C0A;padding:8px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,0.05);}
.tdots{display:flex;gap:5px;}
.tdots span{width:9px;height:9px;border-radius:50%;}
.turl{font:400 10px var(--mono);color:rgba(255,255,255,0.22);flex:1;text-align:center;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.tms{display:none;font:500 9px var(--mono);color:#4ade80;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.2);padding:2px 8px;border-radius:20px;flex-shrink:0;}
.tbody {padding:14px 16px;font:400 11.5px var(--mono);line-height:1.85;min-height:250px;max-height:320px;overflow-y:auto;color:#C9D1D9; overflow-x: hidden;}
.tbody::-webkit-scrollbar{width:3px;}
.tbody::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);}
.tfoot{display:flex;border-top:1px solid rgba(255,255,255,0.05);}
.tinput{flex:1;background:transparent;border:none;color:rgba(255,255,255,0.7);font:400 11px var(--mono);padding:11px 14px;outline:none;}
.tinput::placeholder{color:rgba(255,255,255,0.2);}
.trun{font:700 11px var(--mono);letter-spacing:0.08em;padding:11px 18px;background:var(--red);color:#fff;border:none;cursor:pointer;transition:background 0.15s;}
.trun:hover{background:var(--red2);}
.trun:disabled{opacity:0.4;cursor:not-allowed;}
.jk{color:#7EE787;}.jv{color:#79C0FF;}.js{color:#A5D6FF;}.jb{color:#FF7B72;}.jn{color:#6E7681;}
.t-live-badge{display:flex;align-items:center;gap:5px;font:500 9px var(--mono);color:#4ade80;flex-shrink:0;}

/* ─── STATS STRIP ──────────────────────────────────────────── */
.stats-strip{background:var(--ink);border-top:2px solid var(--red);}
.stats-inner{max-width:1280px;margin:0 auto;display:flex;}
.si{flex:1;padding:20px 0;text-align:center;border-right:1px solid rgba(255,255,255,0.07);transition:background 0.25s;}
.si:last-child{border-right:none;}
.si:hover{background:rgba(255,255,255,0.02);}
.sn{font-family:var(--display);font-size:36px;font-weight:800;letter-spacing:-0.5px;color:#fff;line-height:1;display:block;}
.sn em{color:var(--red);font-style:normal;}
.sl{font:700 9px var(--mono);letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:4px;}

/* ─── SECTION LAYOUT ───────────────────────────────────────── */
.section{padding:80px 0;}
.wrap{max-width:1280px;margin:0 auto;padding:0 28px;}
.eyebrow{font:700 10px var(--mono);letter-spacing:0.15em;text-transform:uppercase;color:var(--red);margin-bottom:10px;}
h2{font-family:var(--display);font-size:clamp(34px,4.5vw,62px);font-weight:800;letter-spacing:-1.5px;color:var(--ink);line-height:1.02;margin-bottom:12px;}
h2 em{font-family:var(--serif);font-weight:700;font-style:italic;letter-spacing:-0.5px;}
.section-lead{font-size:16px;color:var(--mid);max-width:540px;line-height:1.75;margin-bottom:40px;}

/* ─── FEATURE CARDS ────────────────────────────────────────── */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-top:40px;}
.feat-card{background:var(--white);padding:28px 24px;transition:background 0.2s;position:relative;}
.feat-card:hover{background:var(--paper);}
.feat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform 0.3s;}
.feat-card:hover::before{transform:scaleX(1);}
.fc-num{font:700 10px var(--mono);letter-spacing:0.1em;color:var(--soft);margin-bottom:14px;}
.fc-icon{font-size:28px;margin-bottom:12px;}
.fc-title{font:800 17px var(--sans);color:var(--ink);margin-bottom:8px;}
.fc-body {font-size:13px;color:var(--mid);line-height:1.65; overflow-x: hidden;}

/* ─── SPORTS FEATURE DEEP DIVE ─────────────────────────────── */
.sport-tabs{display:flex;gap:2px;padding:3px;background:var(--paper);border:1px solid var(--border);border-radius:10px;width:fit-content;margin-bottom:32px;}
.stab{font:600 11px var(--mono);letter-spacing:0.05em;padding:7px 16px;border-radius:7px;border:none;background:transparent;color:var(--mid);cursor:pointer;transition:all 0.2s;}
.stab.on{background:var(--white);color:var(--ink);box-shadow:var(--shadow-sm);}
.sport-panels{position:relative;}
.sport-panel{display:none;}
.sport-panel.on{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;}
.sp-list{display:flex;flex-direction:column;gap:10px;}
.sp-item{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--white);border:1px solid var(--border);border-radius:10px;box-shadow:var(--shadow-sm);transition:all 0.15s;}
.sp-item:hover{border-color:var(--border2);box-shadow:var(--shadow-md);}
.sp-badge{font:700 9px var(--mono);letter-spacing:0.08em;padding:3px 8px;border-radius:4px;background:var(--greenbg);color:var(--green);border:1px solid rgba(11,122,69,0.2);white-space:nowrap;flex-shrink:0;}
.sp-path{font:500 12px var(--mono);color:var(--ink);margin-bottom:2px;}
.sp-desc{font-size:11px;color:var(--mid);}
.sp-feature-box{background:var(--ink);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-lg);}
.sp-feature-header{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.06);font:700 10px var(--mono);letter-spacing:0.12em;color:rgba(255,255,255,0.35);display:flex;align-items:center;justify-content:space-between;}
.sp-feature-badge{font:700 9px var(--mono);padding:3px 10px;border-radius:20px;background:rgba(215,59,26,0.15);color:var(--red);border:1px solid rgba(215,59,26,0.3);}
.sp-feature-body {padding:14px 18px;font:400 11px var(--mono);line-height:1.9;color:#C9D1D9;min-height:280px;max-height:340px;overflow-y:auto; overflow-x: hidden;}
.sp-feature-body::-webkit-scrollbar{width:3px;}
.sp-feature-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);}

/* ─── ENDPOINTS ────────────────────────────────────────────── */
.ep-bar{display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.ep-search-w{position:relative;flex:1;}
.ep-search-w span{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--soft);pointer-events:none;font-size:15px;}
.ep-search{width:100%;padding:10px 14px 10px 40px;border:1.5px solid var(--border);border-radius:9px;font:400 12px var(--mono);background:var(--white);color:var(--ink);outline:none;transition:border-color 0.2s;}
.ep-search:focus{border-color:var(--red);}
.ep-ct{font:500 10px var(--mono);color:var(--soft);white-space:nowrap;}
.ep-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(285px,1fr));gap:8px;}
.ep-card{background:var(--white);border:1px solid var(--border);border-radius:9px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;cursor:pointer;transition:all 0.15s;box-shadow:var(--shadow-sm);}
.ep-card:hover{border-color:rgba(215,59,26,0.3);box-shadow:var(--shadow-md);transform:translateY(-1px);}
.ep-card.hidden{display:none;}
.get-b{font:700 9px var(--mono);letter-spacing:0.06em;padding:3px 6px;border-radius:3px;background:var(--greenbg);color:var(--green);border:1px solid rgba(11,122,69,0.2);white-space:nowrap;flex-shrink:0;margin-top:2px;}
.ep-path{font:500 12px var(--mono);color:var(--ink);margin-bottom:2px;}
.ep-path mark{background:rgba(215,59,26,0.1);color:var(--red);border-radius:2px;padding:0 2px;}
.ep-desc{font-size:11px;color:var(--mid);}

/* ─── CODE EXAMPLES ─────────────────────────────────────────── */
.code-section{background:var(--ink);padding:80px 0;position:relative;overflow:hidden;}
.code-section::before{content:'';position:absolute;top:-200px;right:-100px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(215,59,26,0.08) 0%,transparent 70%);}
.code-inner{max-width:1280px;margin:0 auto;padding:0 28px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;position:relative;z-index:1;}
.code-eyebrow{font:700 10px var(--mono);letter-spacing:0.15em;text-transform:uppercase;color:var(--red);margin-bottom:10px;}
.code-h2{font-family:var(--display);font-size:clamp(32px,4vw,54px);font-weight:800;letter-spacing:-1.5px;color:#fff;line-height:1.0;margin-bottom:12px;}
.code-lead{font-size:15px;color:rgba(255,255,255,0.45);line-height:1.75;margin-bottom:28px;}
.lang-tabs{display:flex;gap:6px;margin-bottom:14px;}
.ltab{font:700 10px var(--mono);letter-spacing:0.06em;padding:6px 14px;border-radius:5px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);cursor:pointer;transition:all 0.2s;}
.ltab.on{background:rgba(215,59,26,0.15);color:var(--red);border-color:rgba(215,59,26,0.35);}
.code-block{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:10px;overflow:hidden;}
.cb-header{padding:10px 16px;border-bottom:1px solid rgba(255,255,255,0.06);font:500 10px var(--mono);letter-spacing:0.1em;color:rgba(255,255,255,0.25);display:flex;justify-content:space-between;align-items:center;}
.cb-body{padding:18px;font:400 12px var(--mono);line-height:1.85;color:rgba(255,255,255,0.7);overflow-x:auto;}
.cb-body::-webkit-scrollbar{height:3px;}
.cb-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);}
.ck{color:#7EE787;}.cs{color:#A5D6FF;}.cm{color:#FF7B72;}.ckw{color:#FFA657;}.cn{color:rgba(255,255,255,0.3);}
.auth-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px;}
.auth-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:9px;padding:14px 16px;}
.ac-label{font:700 9px var(--mono);letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:8px;}
.ac-code{font:400 12px var(--mono);color:var(--red);}
.rate-grid{display:flex;flex-direction:column;gap:10px;margin-top:28px;}
.rg-item{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;}
.rg-tier{font:600 13px var(--sans);color:#fff;}
.rg-stats{display:flex;gap:20px;}
.rg-stat{text-align:right;}
.rg-v{font:700 13px var(--mono);color:#fff;}
.rg-l{font:500 9px var(--mono);letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.25);}

/* ─── PRICING ─────────────────────────────────────────────── */
.p-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(224px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-top:40px;}
.p-card{background:var(--white);padding:26px 22px;position:relative;transition:background 0.2s;}
.p-card:hover{background:var(--paper);}
.p-card.hot{background:var(--ink);border:none;}
.p-card.hot:hover{background:var(--ink2);}
.p-hot-badge{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--red);color:#fff;font:700 9px var(--mono);letter-spacing:1px;text-transform:uppercase;padding:3px 12px;border-radius:20px;white-space:nowrap;}
.p-sport{font:700 9px var(--mono);letter-spacing:0.12em;text-transform:uppercase;color:var(--soft);margin-bottom:6px;}
.p-card.hot .p-sport{color:rgba(255,255,255,0.35);}
.p-icon{font-size:24px;margin-bottom:8px;display:block;}
.p-name{font:800 19px var(--sans);color:var(--ink);margin-bottom:4px;}
.p-card.hot .p-name{color:#fff;}
