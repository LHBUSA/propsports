function loadScores(){
  var grid=document.getElementById('scores-grid');
  var updated=document.getElementById('scores-updated');
  var btn=document.getElementById('scores-refresh-btn');
  if(!grid)return;
  if(btn){btn.textContent='↻ Loading...';btn.disabled=true;}
  Promise.all([
    fetch(API+'/mlb/schedule/today').then(function(r){return r.json();}).catch(function(){return null;}),
    fetch(API+'/nba/schedule/today').then(function(r){return r.json();}).catch(function(){return null;}),
    fetch(API+'/nhl/schedule/today').then(function(r){return r.json();}).catch(function(){return null;})
  ]).then(function(res){
    var all=[];
    /* MLB */
    var mlb=res[0];
    if(mlb&&mlb.games){mlb.games.forEach(function(g){
      var state=(g.status&&g.status.abstractGameState)||'Preview';
      var away=g.teams&&g.teams.away&&g.teams.away.team?g.teams.away.team.shortName||g.teams.away.team.name:'';
      var home=g.teams&&g.teams.home&&g.teams.home.team?g.teams.home.team.shortName||g.teams.home.team.name:'';
      var aS=g.teams&&g.teams.away&&g.teams.away.score!=null?g.teams.away.score:null;
      var hS=g.teams&&g.teams.home&&g.teams.home.score!=null?g.teams.home.score:null;
      var inning=g.linescore?('Inn '+(g.linescore.currentInning||'')+' '+(g.linescore.inningHalf||'')):((g.status&&g.status.detailedState)||'');
      var gtime=g.gameDate?new Date(g.gameDate).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',timeZoneName:'short'}):'';
      var pp=g.teams&&g.teams.away&&g.teams.away.probablePitcher?g.teams.away.probablePitcher.fullName:'';
      var hp=g.teams&&g.teams.home&&g.teams.home.probablePitcher?g.teams.home.probablePitcher.fullName:'';
      all.push({sport:'mlb',state:state,away:away,home:home,aS:aS,hS:hS,
        info:state==='Live'?inning:(state==='Final'?'Final':gtime),
        pitcher:pp&&hp?pp.split(' ').pop()+' vs '+hp.split(' ').pop():''});
    });}
    /* NBA */
    var nba=res[1];
    if(nba&&nba.games){nba.games.forEach(function(g){
      var name=(g.name||'').split(' at ');
      var away=(name[0]||g.away||'').split(' ').pop();
      var home=(name[1]||g.home||'').split(' ').pop();
      var live=g.status==='in'||g.status==='LIVE';
      var fin=g.status==='post'||g.status==='FINAL';
      var state=live?'Live':(fin?'Final':'Preview');
      all.push({sport:'nba',state:state,away:away,home:home,
        aS:g.awayScore!=null?g.awayScore:null,hS:g.homeScore!=null?g.homeScore:null,
        info:state==='Live'?(g.quarter?'Q'+g.quarter:'Live'):(state==='Final'?'Final':(g.time||'')),
        pitcher:''});
    });}
    /* NHL */
    var nhl=res[2];
    if(nhl&&nhl.games){nhl.games.forEach(function(g){
      var live=g.status==='LIVE'||g.status==='CRIT';
      var fin=g.status==='FINAL'||g.status==='OFF';
      var state=live?'Live':(fin?'Final':'Preview');
      all.push({sport:'nhl',state:state,away:g.away||'',home:g.home||'',
        aS:g.awayScore!=null?g.awayScore:null,hS:g.homeScore!=null?g.homeScore:null,
        info:state==='Live'?(g.period?'P'+g.period:'Live'):(state==='Final'?'Final':(g.startTime||'')),
        pitcher:''});
    });}
    _cachedScores=all;
    renderScores(all);
    if(updated)updated.textContent='Updated '+new Date().toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
    if(btn){btn.textContent='↻ Refresh';btn.disabled=false;}
  }).catch(function(){
    if(btn){btn.textContent='↻ Refresh';btn.disabled=false;}
  });
}

function renderScores(games){
  var grid=document.getElementById('scores-grid');
  if(!grid||!games)return;
  var filtered=_scoresSport==='all'?games:games.filter(function(g){return g.sport===_scoresSport;});
  if(!filtered.length){
    grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:32px;font:400 12px var(--mono);color:var(--soft);">No '+(_scoresSport==='all'?'':_scoresSport.toUpperCase()+' ')+'games today.</div>';
    return;
  }
  filtered=filtered.slice().sort(function(a,b){var o={Live:0,Preview:1,Final:2};return(o[a.state]||1)-(o[b.state]||1);});
  var icons={mlb:'&#9918;',nba:'&#127936;',nhl:'&#127944;'};
  var names={mlb:'MLB',nba:'NBA',nhl:'NHL'};
  grid.innerHTML=filtered.map(function(g){
    var isL=g.state==='Live',isF=g.state==='Final';
    var cls='score-card'+(isL?' live':(isF?' final':''));
    var badge=isL?'<span class="score-live-badge">&#9679; LIVE</span>':(isF?'<span class="score-final-badge">FINAL</span>':'<span class="score-sched-badge">SCHEDULED</span>');
    var aW=isF&&g.aS!=null&&g.hS!=null&&g.aS>g.hS,hW=isF&&g.aS!=null&&g.hS!=null&&g.hS>g.aS;
    var aL=isL&&g.aS!=null&&g.hS!=null&&g.aS>g.hS,hL=isL&&g.aS!=null&&g.hS!=null&&g.hS>g.aS;
    var showSc=g.aS!=null&&g.hS!=null;
    return '<div class="'+cls+'">'+
      '<div class="score-sport">'+icons[g.sport]+' '+names[g.sport]+'<span style="margin-left:auto">'+badge+'</span></div>'+
      '<div class="score-matchup">'+
        '<div class="score-team"><span class="score-name'+(aW?' winner':'')+'">'+(g.away||'&mdash;')+'</span>'+(showSc?'<span class="score-num'+(aL?' leader':'')+'">'+g.aS+'</span>':'')+'</div>'+
        '<div class="score-divider"></div>'+
        '<div class="score-team"><span class="score-name'+(hW?' winner':'')+'">'+(g.home||'&mdash;')+'</span>'+(showSc?'<span class="score-num'+(hL?' leader':'')+'">'+g.hS+'</span>':'')+'</div>'+
      '</div>'+
      '<div class="score-info">'+(g.info||'')+'</div>'+
      (g.pitcher?'<div class="score-pitcher">'+g.pitcher+'</div>':'')+
    '</div>';
  }).join('');
}

