    vFed.classList.remove('loading');
    vFed.innerHTML = `${fmt(fed,2)}<span class="u">%</span>`;
    const bFed = document.getElementById('b-fed');
    bFed.textContent = fed > 5 ? 'Elevated' : fed > 4 ? 'Moderate' : 'Low';
    bFed.className = 'tc-badge ' + (fed > 5 ? 'b-dn' : fed > 4 ? 'b-nt' : 'b-up');
    document.getElementById('d-fed').textContent = 'Fed policy rate';
    // Fed sparkline using same data repeated for shape (monthly data → 8 points)
    const fedArr = Array(8).fill(fed);
    spark('sp-fed', fedArr, '#6fa0ff', false);
  }

  // BKPP
  const edge = m.bkpp.edge;
  const vBkpp = document.getElementById('v-bkpp');
  vBkpp.classList.remove('loading');
  vBkpp.innerHTML = `+${fmtK(edge)}<span class="u">avg</span>`;
  document.getElementById('d-bkpp').textContent = `vs cash · $${Math.round(m.bkpp.arv/1000)}K ARV`;
  // Synthetic sparkline showing edge growing as rates rise
  const edgeHx = m.rate30.history.length > 1
    ? m.rate30.history.map(d => Math.round(edge * (0.8 + (d.value - 6.5) * 0.15)))
    : [14000,16000,17000,18500,19000,20000,20500,edge];
  spark('sp-bkpp', edgeHx, '#e2b55a', false);

  // Chart
  if (m.rate30.history.length >= 2) {
    buildChart(m.rate30.history);
    document.getElementById('ch-val').textContent = r30 ? `${fmt(r30,2)}%` : '—';
  }

  // Tape
  buildTape();
}

