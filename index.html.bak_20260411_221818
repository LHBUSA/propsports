}

function spark(id, data, color, inv) {
  const svg = document.getElementById(id);
  if (!svg || !data || data.length < 2) return;
  const vals = data.map(d => typeof d === 'object' ? d.value : d);
  const W=64, H=26, p=3;
  const mn=Math.min(...vals), mx=Math.max(...vals), rng=mx-mn||0.01;
  const pts = vals.map((v,i) => {
    const x = p + i/(vals.length-1)*(W-p*2);
    const y = inv ? p+(v-mn)/rng*(H-p*2) : H-p-(v-mn)/rng*(H-p*2);
    return `${x},${y}`;
  }).join(' ');
  const last = pts.split(' ').at(-1).split(',');
  svg.innerHTML = `<polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linejoin="round" opacity="0.7"/><circle cx="${last[0]}" cy="${last[1]}" r="2.5" fill="${color}"/>`;
}

function buildChart(history) {
  const svg = document.getElementById('ch-svg');
  if (!history || history.length < 2) return;
  const W=372, H=42, p={l:3,r:3,t:4,b:4};
  const rates = history.map(d => d.value);
  const dates = history.map(d => d.date);
  const mn=Math.min(...rates)-0.06, mx=Math.max(...rates)+0.06, rng=mx-mn;
  const xs = rates.map((_,i)=>p.l+(i/(rates.length-1))*(W-p.l-p.r));
  const ys = rates.map(r=>H-p.b-((r-mn)/rng)*(H-p.t-p.b));
  const pts = xs.map((x,i)=>`${x},${ys[i]}`).join(' ');
  const fill = `${xs[0]},${H} ${pts} ${xs.at(-1)},${H}`;
  const grid = [Math.round(mn*10)/10, Math.round((mn+rng/2)*10)/10, Math.round(mx*10)/10].map(gr=>{
    const gy=H-p.b-((gr-mn)/rng)*(H-p.t-p.b);
    return gy>=1&&gy<=H-1 ? `<line x1="${p.l}" y1="${gy}" x2="${W-p.r}" y2="${gy}" stroke="rgba(255,255,255,0.035)" stroke-width="1"/>` : '';
  }).join('');
  svg.innerHTML = `
    <defs><linearGradient id="rg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#c49a3c" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#c49a3c" stop-opacity="0"/>
    </linearGradient></defs>
    ${grid}
    <polygon points="${fill}" fill="url(#rg)"/>
    <polyline points="${pts}" fill="none" stroke="#c49a3c" stroke-width="1.5" stroke-linejoin="round"/>
    ${xs.map((x,i)=>`<circle cx="${x}" cy="${ys[i]}" r="${i===rates.length-1?2.5:1.5}" fill="${i===rates.length-1?'#c49a3c':'rgba(196,154,60,0.4)'}" data-i="${i}"/>`).join('')}
  `;
  // hit zones
  xs.forEach((x,i) => {
    const hw = (W-p.l-p.r) / Math.max(rates.length-1,1);
    const r = document.createElementNS('http://www.w3.org/2000/svg','rect');
    r.setAttribute('x', x-hw/2); r.setAttribute('y', 0);
    r.setAttribute('width', hw); r.setAttribute('height', H);
    r.setAttribute('fill','transparent'); r.style.cursor='pointer';
    const label = dates[i] ? new Date(dates[i]+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'}) : `Wk ${i+1}`;
    r.addEventListener('mouseenter', () => {
      const tip=document.getElementById('c-tip');
      const area=document.querySelector('.chart-area');
      const rect=area.getBoundingClientRect();
      tip.textContent=`${label} · ${rates[i].toFixed(2)}%`;
      tip.style.left=(x/W*rect.width)+'px';
      tip.style.top=(ys[i]/H*rect.height-4)+'px';
      tip.classList.add('show');
      document.getElementById('ch-val').textContent=`${rates[i].toFixed(2)}%`;
    });
    r.addEventListener('mouseleave', () => {
      document.getElementById('c-tip').classList.remove('show');
      document.getElementById('ch-val').textContent=`${rates.at(-1).toFixed(2)}%`;
    });
    svg.appendChild(r);
  });
  // week labels — show first, middle, last
  const shown = [0, Math.floor(dates.length/2), dates.length-1];
  const weeksEl = document.getElementById('ch-weeks');
  weeksEl.innerHTML = dates.map((d,i) => {
    if (!shown.includes(i)) return `<span></span>`;
    const lbl = d ? new Date(d+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'}) : `Wk ${i+1}`;
    return `<span>${lbl}</span>`;
  }).join('');
}

function buildTape() {
  const m = mkt;
