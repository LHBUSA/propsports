<script>
// ═══ CHAT ═══
// On Cloudflare Pages: API = '' (same origin, worker handles /stream /market etc.)
// On Vercel: API = 'https://localhomebuyersusa.ai' (point to the worker domain)
const API = window.__CAL_API__ || '';
let sid = sessionStorage.getItem('c_s') || null;
let uid = localStorage.getItem('c_u') || ('u_' + Math.random().toString(36).slice(2) + Date.now().toString(36));
localStorage.setItem('c_u', uid);
let lang = 'en', busy = false;

function setL(l) {
  lang = l;
  document.getElementById('ben').classList.toggle('on', l==='en');
  document.getElementById('bes').classList.toggle('on', l==='es');
  document.getElementById('msg').placeholder = l==='es' ? 'Pregúntale a Cal sobre vender tu casa…' : 'Ask Cal anything about selling your home…';
}

const inp = document.getElementById('msg');
const sBtn = document.getElementById('sbtn');
inp.addEventListener('input', () => { inp.style.height='auto'; inp.style.height=Math.min(inp.scrollHeight,120)+'px'; sBtn.classList.toggle('live', inp.value.trim().length>0); });
inp.addEventListener('keydown', e => { if (e.key==='Enter'&&!e.shiftKey) { e.preventDefault(); if (!busy&&inp.value.trim()) doSend(); } });

function hideWelcome() {
  const w=document.getElementById('welcome');
  if (w&&w.style.display!=='none') {
    w.style.transition='opacity .3s ease,transform .3s ease'; w.style.opacity='0'; w.style.transform='translateY(-6px)';
    setTimeout(()=>w.style.display='none', 300);
  }
}

function scrollBot() { const f=document.getElementById('feed'); f.scrollTo({top:f.scrollHeight,behavior:'smooth'}); }
function esc(t) { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function md(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/\[([^\]]+)\]\((https?:\/\/[^\)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>')
    .replace(/(https?:\/\/[^\s<>"]+)/g, u=>`<a href="${u}" target="_blank" rel="noopener">${u}</a>`)
    .split('\n\n').map(p=>p?`<p>${p.replace(/\n/g,'<br>')}</p>`:'').join('');
}

function addMsg(role, text, streaming=false) {
  hideWelcome();
  const msgs=document.getElementById('msgs');
  const w=document.createElement('div'); w.className=`msg ${role}`;
  const av=document.createElement('div'); av.className='m-avi'; av.textContent=role==='cal'?'🐝':'👤';
  const bd=document.createElement('div'); bd.className='m-body';
  const who=document.createElement('div'); who.className='m-who'; who.textContent=role==='cal'?'Cal':'You';
  const bub=document.createElement('div'); bub.className='bub'+(streaming?' streaming':'');
  bub.innerHTML=role==='cal'?md(text):esc(text);
  bd.appendChild(who); bd.appendChild(bub); w.appendChild(av); w.appendChild(bd);
  msgs.appendChild(w); scrollBot(); return bub;
}

function showTyping() {
  const msgs=document.getElementById('msgs');
  const el=document.createElement('div'); el.className='ty-row'; el.id='ty';
