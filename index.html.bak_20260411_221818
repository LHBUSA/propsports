    const bEl = document.getElementById('b-inv');
    bEl.textContent = cond;
    bEl.className = 'tc-badge ' + (inv < 3 ? 'b-dn' : inv < 5 ? 'b-nt' : 'b-up');
    spark('sp-inv', m.inventory.history, '#c49a3c', false);
  }

  // Fed rate
  const vFed = document.getElementById('v-fed');
