function fmt(v, dec=2) { return v != null ? v.toFixed(dec) : '—'; }
function fmtK(v) { return v != null ? `$${Math.round(v/1000)}K` : '—'; }

function setFreshness(state) {
  const pip = document.getElementById('tf-pip');
  const lbl = document.getElementById('tf-label');
  pip.className = 'tf-pip ' + state;
  if (state === 'live') {
    const now = new Date();
    lbl.textContent = `Live · Updated ${now.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}`;
  } else if (state === 'loading') {
    lbl.textContent = 'Loading market data…';
  } else if (state === 'error') {
    lbl.textContent = 'Using cached data';
