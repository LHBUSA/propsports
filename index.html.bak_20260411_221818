// ── FETCH REAL DATA ──
async function loadMarketData() {
  setFreshness('loading');
  try {
    const res = await fetch(`${API}/market`, { headers: { 'Accept': 'application/json' } });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    mkt = data;
    populateCells();
    populateMobileStrip();
    buildInsights();
    setFreshness('live');
  } catch (err) {
    console.warn('Market data fetch failed:', err.message);
    setFreshness('error');
    // Still build insights with fallback
    buildInsights();
  }
}


