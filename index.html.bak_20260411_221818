      c.classList.toggle('hidden',!hit);
      if(hit){n++;var p=c.querySelector('.ep-path');if(p)p.innerHTML=q?hl(p.textContent,q):p.textContent;}
    });
    if(ct)ct.textContent=n+' endpoint'+(n===1?'':'s');
  });
  function hl(t,q){return t.replace(new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi'),'<mark>$1</mark>');}
})();

