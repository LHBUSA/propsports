  .section{padding:52px 0;}
  .stats-inner{flex-wrap:wrap;}
  .si{width:50%;border-bottom:1px solid rgba(255,255,255,0.07);}
  .si:nth-child(odd){border-right:1px solid rgba(255,255,255,0.07);}
  .feat-grid{grid-template-columns:1fr;}
  .p-grid{grid-template-columns:1fr;}
  .use-grid{grid-template-columns:1fr;}
  .sponsor-inner{padding:36px 20px;grid-template-columns:1fr;}
  .sp-copy p{max-width:100%;}
  .footer-top{grid-template-columns:1fr;padding:40px 20px 28px;}
  .footer-bottom{padding:16px 20px;flex-direction:column;text-align:center;}
  .hero-inner h1{font-size:clamp(52px,13vw,80px);letter-spacing:-1px;}
  .auth-grid{grid-template-columns:1fr;}
  .rg-stats{flex-direction:column;gap:4px;text-align:left;}
  .code-inner{padding:0 20px;}
  .cta-band{padding:48px 20px;}
  #ticker{display:none;}
}
</style>






