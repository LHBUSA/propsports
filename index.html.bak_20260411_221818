  const items = [
    {k:'FED RATE', v: fed ? `${fmt(fed,2)}%` : '—', c: fed>5?'dn':'', a: fed>5?'↑':''},
    {k:'30YR FIXED', v: r30 ? `${fmt(r30,2)}%` : '—', c:'dn', a:'↑'},
    {k:'15YR FIXED', v: r15 ? `${fmt(r15,2)}%` : '—', c:'dn', a:'↑'},
    {k:'INVENTORY', v: inv ? `${fmt(inv,1)}mo` : '—', c:'', a:''},
    {k:'BKPP EDGE', v: edge ? `+${fmtK(edge)} avg` : '—', c:'gd', a:'↑'},
    {k:'LIST/SALE', v:'98.2%', c:'up', a:'↑'},
    {k:'CASH BUYERS', v:'32%', c:'', a:''},
    {k:'NEW LISTINGS', v:'−3.1%', c:'dn', a:'↓'},
    {k:'MARKET', v: m.marketCondition==='seller'?"Seller's":m.marketCondition==='buyer'?"Buyer's":'Balanced', c: m.marketCondition==='seller'?'gd':'', a:''},
  ];
  const tape = document.getElementById('tape');
  const all = [...items,...items];
  tape.innerHTML = all.map(t=>`<span class="ti"><span class="ti-k">${t.k}</span><span class="ti-v ${t.c}">${t.v}</span>${t.a?`<span class="ti-a ${t.c}">${t.a}</span>`:''}</span>`).join('');
}

function populateCells() {
  const m = mkt;
