<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blk:      #080807;
  --blk2:     #0e0d0c;
  --blk3:     #161513;
  --blk4:     #1e1c19;
  --blk5:     #252220;
  --gold:     #c49a3c;
  --gold-hi:  #e2b55a;
  --gold-lo:  rgba(196,154,60,0.1);
  --grn:      #3db87a;
  --red:      #e05c4a;
  --cream:    #ede8df;
  --cream2:   #bdb5a8;
  --cream3:   #7a7268;
  --cream4:   #4e4840;
  --bdr:      rgba(255,255,255,0.055);
  --bdr-g:    rgba(196,154,60,0.2);
  --serif:   'Cormorant', Georgia, serif;
  --mono:    'DM Mono', monospace;
  --sans:    'Plus Jakarta Sans', sans-serif;
}

html, body {
  height: 100%;
  background: var(--blk);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

.app { display: flex; height: 100dvh; }

/* ═══════════════════════════════════════
   LEFT PANEL
═══════════════════════════════════════ */
.panel {
  width: 420px;
  min-width: 420px;
  background: var(--blk2);
  border-right: 1px solid var(--bdr);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.orbs { position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(70px);
}

.orb1 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(196,154,60,0.11) 0%, transparent 70%);
  top: -60px; left: -40px;
  animation: of1 14s ease-in-out infinite;
}

.orb2 {
  width: 220px; height: 220px;
  background: radial-gradient(circle, rgba(196,154,60,0.06) 0%, transparent 70%);
  bottom: 80px; right: -30px;
  animation: of2 18s ease-in-out infinite;
}

@keyframes of1 { 0%,100%{transform:translate(0,0)} 40%{transform:translate(18px,28px)} 70%{transform:translate(-12px,14px)} }
@keyframes of2 { 0%,100%{transform:translate(0,0)} 55%{transform:translate(-16px,-22px)} }

.orbs::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  opacity: 0.7;
}

/* ── BRAND ── */
.panel-brand {
  position: relative;
  z-index: 1;
  padding: 28px 26px 22px;
  flex-shrink: 0;
  opacity: 0;
  animation: su 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s forwards;
}

.p-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }

.p-logo { display: flex; align-items: center; gap: 9px; }

.p-bee {
  width: 30px; height: 30px;
  border-radius: 7px;
  background: var(--blk4);
  border: 1px solid var(--bdr-g);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 0 10px rgba(196,154,60,0.1);
}

.p-name { font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream2); }

.p-domain { font-family: var(--mono); font-size: 9px; color: var(--cream4); letter-spacing: 0.05em; padding: 3px 8px; border-radius: 99px; border: 1px solid var(--bdr); background: rgba(255,255,255,0.015); }

.p-kicker { display: flex; align-items: center; gap: 9px; margin-bottom: 12px; }
.p-rule { width: 26px; height: 1px; background: linear-gradient(90deg, var(--gold), transparent); }
.p-kicker-txt { font-family: var(--mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); }

.p-hed { font-family: var(--serif); font-size: 46px; font-weight: 300; line-height: 0.95; letter-spacing: -0.01em; color: var(--cream); margin-bottom: 10px; }
.p-hed .ig { font-style: italic; color: var(--gold-hi); }
.p-hed .lw { color: var(--cream3); }

.p-desc { font-size: 12px; font-weight: 300; color: var(--cream3); line-height: 1.7; }

.panel-div { position: relative; z-index: 1; height: 1px; background: var(--bdr); flex-shrink: 0; }

/* ═══════════════════════════════════════
   TICKER
═══════════════════════════════════════ */
.ticker { position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* ── DATA FRESHNESS ── */
.t-freshness {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 5px 14px;
  background: var(--blk3);
  border-bottom: 1px solid var(--bdr);
  flex-shrink: 0;
}

.tf-left { display: flex; align-items: center; gap: 6px; }

.tf-pip {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--cream4);
  transition: background 0.3s;
}

.tf-pip.live { background: var(--grn); box-shadow: 0 0 4px rgba(61,184,122,0.6); animation: pp 2s ease infinite; }
.tf-pip.loading { background: var(--gold); animation: pp 0.8s ease infinite; }
.tf-pip.error { background: var(--red); }

@keyframes pp { 0%,100%{opacity:1} 50%{opacity:.4} }

.tf-label { font-family: var(--mono); font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream4); }
.tf-source { font-family: var(--mono); font-size: 8px; color: var(--cream4); letter-spacing: 0.04em; opacity: 0.7; }

/* ── TAPE ── */
.tape-shell { position: relative; background: var(--blk3); border-bottom: 1px solid var(--bdr); height: 30px; overflow: hidden; flex-shrink: 0; }
.tape-shell::before, .tape-shell::after { content: ''; position: absolute; top: 0; bottom: 0; width: 28px; z-index: 2; pointer-events: none; }
.tape-shell::before { left: 0; background: linear-gradient(90deg, var(--blk3), transparent); }
.tape-shell::after  { right: 0; background: linear-gradient(-90deg, var(--blk3), transparent); }

.tape { display: flex; align-items: center; height: 100%; white-space: nowrap; animation: scroll 32s linear infinite; }
.tape:hover { animation-play-state: paused; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

.ti { display: inline-flex; align-items: center; gap: 6px; padding: 0 16px; font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.03em; border-right: 1px solid var(--bdr); }
.ti-k { color: var(--cream4); text-transform: uppercase; font-size: 8px; letter-spacing: 0.12em; }
.ti-v { color: var(--cream); }
.ti-v.up { color: var(--grn); }
.ti-v.dn { color: var(--red); }
.ti-v.gd { color: var(--gold-hi); }
.ti-a { font-size: 7.5px; }
.ti-a.up { color: var(--grn); }
.ti-a.dn { color: var(--red); }

/* skeleton shimmer for loading */
.skeleton {
  background: linear-gradient(90deg, var(--blk3) 25%, var(--blk4) 50%, var(--blk3) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 3px;
  display: inline-block;
}

@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ── 2×2 GRID ── */
.t-grid { display: grid; grid-template-columns: 1fr 1fr; flex-shrink: 0; }

.t-cell {
  padding: 12px 14px 10px;
  background: var(--blk2);
  border-bottom: 1px solid var(--bdr);
  border-right: 1px solid var(--bdr);
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: background 0.18s;
}

.t-cell:nth-child(even) { border-right: none; }
.t-cell::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(196,154,60,0.07), transparent 55%); opacity: 0; transition: opacity 0.2s; }
.t-cell:hover { background: var(--blk3); }
.t-cell:hover::after { opacity: 1; }
.t-cell.on { background: var(--blk4); outline: 1px solid var(--bdr-g); outline-offset: -1px; }
.t-cell.on::after { opacity: 1; }

.tc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
.tc-k { font-family: var(--mono); font-size: 8px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cream4); }

.tc-badge { font-family: var(--mono); font-size: 7px; padding: 1px 5px; border-radius: 3px; letter-spacing: 0.06em; }
.b-dn  { background: rgba(224,92,74,0.12); color: var(--red); }
.b-up  { background: rgba(61,184,122,0.1); color: var(--grn); }
.b-gd  { background: var(--gold-lo); color: var(--gold-hi); border: 1px solid var(--bdr-g); }
.b-nt  { background: rgba(255,255,255,0.04); color: var(--cream3); }

.tc-val { font-family: var(--serif); font-size: 24px; font-weight: 300; line-height: 1; color: var(--cream); letter-spacing: -0.01em; margin-bottom: 3px; }
.tc-val .u { font-family: var(--mono); font-size: 9px; color: var(--cream3); margin-left: 1px; }
.tc-val.loading .num { display: none; }
.tc-val.loading::after { content: ''; display: inline-block; width: 60px; height: 20px; background: linear-gradient(90deg, var(--blk3) 25%, var(--blk4) 50%, var(--blk3) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 3px; vertical-align: middle; }

.tc-delta { font-family: var(--mono); font-size: 8.5px; color: var(--cream4); line-height: 1; }
.tc-delta.up { color: var(--grn); }
.tc-delta.dn { color: var(--red); }
.tc-delta.gd { color: var(--gold-hi); }

.tc-spark { position: absolute; bottom: 2px; right: 3px; width: 64px; height: 26px; opacity: 0.35; }

/* ── DETAIL ── */
.t-detail { background: var(--blk3); border-bottom: 1px solid var(--bdr-g); max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.16,1,0.3,1); flex-shrink: 0; }
.t-detail.open { max-height: 170px; }
.t-detail-inner { padding: 12px 16px 10px; }
.t-detail-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.t-detail-title { font-family: var(--serif); font-size: 12.5px; font-style: italic; font-weight: 300; color: var(--cream2); }
.t-esc { font-family: var(--mono); font-size: 8px; color: var(--cream4); cursor: pointer; padding: 2px 7px; border: 1px solid var(--bdr); border-radius: 3px; letter-spacing: 0.08em; transition: color .15s, border-color .15s; }
.t-esc:hover { color: var(--gold-hi); border-color: var(--bdr-g); }
.t-rows { display: flex; flex-direction: column; gap: 0; }
.t-row { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
.t-row:last-child { border-bottom: none; }
.t-row-k { font-family: var(--mono); font-size: 8.5px; letter-spacing: 0.08em; color: var(--cream4); text-transform: uppercase; }
.t-row-v { font-family: var(--mono); font-size: 9.5px; color: var(--cream2); }
.t-row-v.good { color: var(--grn); }
.t-row-v.warn { color: var(--red); }
.t-row-v.gd   { color: var(--gold-hi); }

/* ── CHART ── */
.t-chart { flex-shrink: 0; padding: 10px 14px 7px; background: var(--blk2); border-bottom: 1px solid var(--bdr); }
.t-chart-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
.t-chart-label { font-family: var(--mono); font-size: 7.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cream4); }
.t-chart-val { font-family: var(--mono); font-size: 9.5px; color: var(--gold-hi); letter-spacing: 0.04em; }
.t-chart-src { font-family: var(--mono); font-size: 7px; color: var(--cream4); opacity: 0.6; }

.chart-area { position: relative; height: 42px; }
.chart-area svg { width: 100%; height: 100%; overflow: visible; }

.c-tip { position: absolute; background: var(--blk5); border: 1px solid var(--bdr-g); border-radius: 4px; padding: 3px 7px; font-family: var(--mono); font-size: 9px; color: var(--cream); pointer-events: none; opacity: 0; transition: opacity 0.12s; transform: translate(-50%, -100%); margin-top: -5px; white-space: nowrap; z-index: 10; letter-spacing: 0.04em; }
.c-tip.show { opacity: 1; }

.t-chart-weeks { display: flex; justify-content: space-between; margin-top: 3px; font-family: var(--mono); font-size: 7px; color: var(--cream4); letter-spacing: 0.04em; }

/* ── INSIGHT ── */
.t-insight { flex: 1; display: flex; align-items: center; gap: 9px; padding: 10px 14px; background: var(--blk2); min-height: 0; }
.t-insight-icon { font-size: 12px; flex-shrink: 0; }
.t-insight-txt { font-family: var(--serif); font-size: 12px; font-style: italic; font-weight: 300; color: var(--cream3); line-height: 1.5; flex: 1; min-width: 0; transition: opacity 0.25s; }
.t-insight-txt strong { color: var(--gold-hi); font-style: normal; font-weight: 400; }
.t-insight-btn { font-family: var(--mono); font-size: 7.5px; letter-spacing: 0.1em; color: var(--cream4); cursor: pointer; padding: 3px 7px; border: 1px solid var(--bdr); border-radius: 3px; flex-shrink: 0; transition: color .15s, border-color .15s; white-space: nowrap; }
.t-insight-btn:hover { color: var(--gold-hi); border-color: var(--bdr-g); }
.t-insight-btn.spin { animation: spin 0.5s linear; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── FOOTER ── */
.panel-foot { position: relative; z-index: 1; padding: 10px 16px; border-top: 1px solid var(--bdr); display: flex; align-items: center; justify-content: space-between; background: var(--blk2); flex-shrink: 0; }
.fp-pills { display: flex; gap: 5px; }
.fp-pill { display: flex; align-items: center; gap: 4px; padding: 3px 7px; border-radius: 99px; border: 1px solid var(--bdr); background: rgba(255,255,255,0.015); font-family: var(--mono); font-size: 9px; color: var(--cream4); }
.fp-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--grn); box-shadow: 0 0 4px rgba(61,184,122,0.7); }
.fp-phone { font-family: var(--mono); font-size: 9.5px; color: var(--cream4); text-decoration: none; letter-spacing: 0.04em; transition: color .15s; }
.fp-phone:hover { color: var(--gold-hi); }

/* ═══════════════════════════════════════
   RIGHT — CHAT
═══════════════════════════════════════ */
.chat { flex: 1; display: flex; flex-direction: column; min-width: 0; background: var(--blk); position: relative; }
.chat::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 500px; height: 220px; background: radial-gradient(ellipse at 50% 0%, rgba(196,154,60,0.04) 0%, transparent 70%); pointer-events: none; z-index: 0; }

.chat-bar { display: flex; align-items: center; justify-content: space-between; padding: 17px 26px; border-bottom: 1px solid var(--bdr); flex-shrink: 0; position: relative; z-index: 2; opacity: 0; animation: fi 0.5s ease 0.9s forwards; }
.cb-id { display: flex; align-items: center; gap: 10px; }
.cb-bee { width: 28px; height: 28px; border-radius: 50%; background: var(--blk3); border: 1px solid var(--bdr-g); display: flex; align-items: center; justify-content: center; font-size: 13px; }
.cb-name { font-weight: 600; font-size: 13px; color: var(--cream); }
.cb-status { display: flex; align-items: center; gap: 5px; font-family: var(--mono); font-size: 9px; color: var(--grn); letter-spacing: 0.06em; }
.live-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--grn); box-shadow: 0 0 5px rgba(61,184,122,0.7); animation: lp 2.5s ease infinite; }
@keyframes lp { 0%,100%{opacity:1} 50%{opacity:.45} }
.cb-right { display: flex; align-items: center; gap: 8px; }
.cb-phone { display: flex; align-items: center; gap: 5px; font-family: var(--mono); font-size: 9.5px; color: var(--cream3); text-decoration: none; padding: 5px 11px; border: 1px solid var(--bdr); border-radius: 99px; letter-spacing: 0.04em; transition: all 0.2s; }
.cb-phone:hover { border-color: var(--bdr-g); color: var(--gold-hi); background: var(--gold-lo); }
.cb-offer { padding: 7px 17px; border-radius: 99px; background: var(--gold); color: var(--blk); font-size: 11px; font-weight: 600; font-family: var(--sans); letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; text-decoration: none; border: none; transition: all 0.2s; }
